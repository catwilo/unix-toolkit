#!/bin/sh
# ncssh — like nssh, but the LAST command's output is mirrored to the
# clipboard (server-local + client terminal via OSC52/clipso).
#
# Usage:  ncssh <alias> [remote-command...]
#
# Activation: exports LC_NCSSH=1, forwarded over SSH (AcceptEnv LC_*).
# The server's ~/.zshrc sources lib/capture.zsh only when LC_NCSSH is set,
# so normal nssh sessions carry zero overhead.
#
# Exit codes:
#   0   session ended normally
#   1   alias not found, db missing, or arg error
#   N   exit code forwarded from ssh

set -eu

_self="$0"
case "$_self" in */*) ;; *) _self="$(command -v "$_self")" ;; esac
if _real="$(readlink -f "$_self" 2>/dev/null)" && [ -n "$_real" ]; then
    _self="$_real"
else
    while [ -L "$_self" ]; do
        _link="$(readlink "$_self")"
        case "$_link" in /*) _self="$_link" ;; *) _self="$(dirname "$_self")/$_link" ;; esac
    done
fi
_bindir="$(cd "$(dirname "$_self")" && pwd -P)"
BASE="${NOEMAP_BASE:-$(dirname "$_bindir")}"
LIB="$BASE/lib"
DB="$BASE/state/devices.db"
CFG="$BASE/config/ssh_config"

for _mod in util.sh devices.sh; do
    _path="$LIB/$_mod"
    if [ ! -f "$_path" ]; then
        printf '[ERROR] missing module: %s\n' "$_mod" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    . "$_path"
done

case "${1:-}" in
    -h|--help)
        printf 'usage: ncssh <alias> [command...]\n'
        printf '  Like nssh, but mirrors the last command output to the\n'
        printf '  clipboard (server-local + client via OSC52/clipso).\n'
        exit 0
        ;;
esac

[ $# -ge 1 ] || {
    printf 'usage: ncssh <alias> [command...]\n' >&2
    exit 1
}

_name="$1"
shift

_row="$(resolve_device "$_name" "$DB")"
_ip="$(printf '%s\n'   "$_row" | cut -d'|' -f1)"
_user="$(printf '%s\n' "$_row" | cut -d'|' -f2)"
_port="$(printf '%s\n' "$_row" | cut -d'|' -f3)"

_user="$(_ensure_user "$_name" "$DB" "$_user")"

[ -n "$_user" ] || {
    printf '[ERROR] no user configured for "%s"\n' "$_name" >&2
    exit 1
}

export NOEMAP_SSH_ROLE=interactive
export LC_NCSSH=1

if [ -f "$CFG" ]; then
    exec ssh -F "$CFG" -o SendEnv=LC_NCSSH -p "$_port" "${_user}@${_ip}" "$@"
else
    log WARN "ssh_config not found at $CFG — connecting without it"
    exec ssh -o SendEnv=LC_NCSSH -p "$_port" "${_user}@${_ip}" "$@"
fi
