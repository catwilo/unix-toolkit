#!/bin/sh
# nclipc — execute a command on a registered device and copy output to clipboard
#
# Usage:
#   nclipc <alias>              prompt for command interactively (Ctrl+D to send)
#   nclipc <alias> -- <cmd>     run command directly
#
# Output is printed to stdout AND copied to clipboard via clipso.
#
# Environment:
#   NOEMAP_BASE   — override project root    (default: ~/dev/noemap)
#   CLIPSO_BIN    — override clipso location (default: auto-detected)

set -eu

_self="$0"
case "$_self" in */*) ;; *) _self="$(command -v "$_self")" ;; esac
if _real="$(readlink -f "$_self" 2>/dev/null)" && [ -n "$_real" ]; then
    _self="$_real"
else
    while [ -L "$_self" ]; do
        _link="$(readlink "$_self")"
        case "$_link" in /*) _self="$_link" ;; *) _self="$(dirname "$_self")/$_link" ;; esac
    done
fi
_bindir="$(cd "$(dirname "$_self")" && pwd -P)"
BASE="${NOEMAP_BASE:-$(dirname "$_bindir")}"
LIB="$BASE/lib"
DB="$BASE/state/devices.db"
CFG="$BASE/config/ssh_config"
CLIPSO="${CLIPSO_BIN:-$(command -v clipso 2>/dev/null || echo "$HOME/scripts/clipso/clipso.sh")}"

for _mod in util.sh devices.sh; do
    _path="$LIB/$_mod"
    [ -f "$_path" ] || { printf '[ERROR] missing module: %s\n' "$_mod" >&2; exit 1; }
    # shellcheck source=/dev/null
    . "$_path"
done

case "${1:-}" in
    -h|--help)
        printf 'usage: nclipc <alias> [-- <command...>]\n'
        printf '  Execute a command on a registered device; copy output to clipboard.\n'
        printf '  Without -- <command>, prompts interactively (Ctrl+D to send).\n'
        exit 0
        ;;
esac

[ $# -ge 1 ] || { printf 'usage: nclipc <alias> [-- <command...>]\n' >&2; exit 1; }

_alias="$1"; shift

_row="$(resolve_device "$_alias" "$DB")"
_ip="$(printf '%s\n'   "$_row" | cut -d'|' -f1)"
_user="$(printf '%s\n' "$_row" | cut -d'|' -f2)"
_port="$(printf '%s\n' "$_row" | cut -d'|' -f3)"
_user="$(_ensure_user "$_alias" "$DB" "$_user")"
[ -n "$_user" ] || { log ERROR "no user configured for \"$_alias\""; exit 1; }

# Resolve command: -- <cmd> or interactive prompt
if [ "${1:-}" = "--" ]; then
    shift
    [ $# -ge 1 ] || { printf '[ERROR] -- requires a command\n' >&2; exit 1; }
    _cmd="$*"
else
    printf 'command to run on %s (Ctrl+D to send):\n> ' "$_alias" >&2
    _cmd="$(cat)"
    [ -n "$_cmd" ] || { printf '[ERROR] empty command\n' >&2; exit 1; }
fi

# Run remote command
_tmp="$(mktemp "${TMPDIR:-/tmp}/nclipc.XXXXXX")"
trap 'rm -f "$_tmp"' EXIT INT TERM

if [ -f "$CFG" ]; then
    ssh -F "$CFG" -p "$_port" -o ConnectTimeout=10 -o BatchMode=yes \
        "${_user}@${_ip}" "$_cmd" > "$_tmp" 2>&1
else
    ssh -p "$_port" -o ConnectTimeout=10 -o BatchMode=yes \
        "${_user}@${_ip}" "$_cmd" > "$_tmp" 2>&1
fi || { log ERROR "SSH command failed on \"$_alias\""; cat "$_tmp" >&2; exit 1; }

# Print to stdout
cat "$_tmp"

# Copy to clipboard
if [ -x "$CLIPSO" ]; then
    "$CLIPSO" "$_tmp" >/dev/null
else
    log WARN "clipso not found — output printed to stdout only"
fi
