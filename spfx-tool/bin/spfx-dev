#!/usr/bin/env bash
# bin/spfx-dev — Start the SPFx development server via Podman.
# Usage: spfx-dev <name> [--port <n>] [--host <ip>]
# shellcheck shell=bash
set -euo pipefail

export SPFX_DIR="${SPFX_DIR:-$HOME/dev/spfx}"
export LOG_FILE="${SPFX_DIR}/logs/spfx-dev-$(date '+%Y%m%d-%H%M%S').log"
mkdir -p "${SPFX_DIR}/logs"

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/core.sh
source "${_SCRIPT_DIR}/lib/core.sh"
# shellcheck source=lib/runtime.sh
source "${_SCRIPT_DIR}/lib/runtime.sh"
# shellcheck source=lib/state.sh
source "${_SCRIPT_DIR}/lib/state.sh"


require_podman
spfx_load_versions
# Skip expensive container verify if cache is fresh.
if state_verify_cache_valid; then
    log_debug "Verify cache hit — skipping container check"
else
    _verify_rc=0
    "${SPFX_DIR}/bin/spfx-verify" --quiet || _verify_rc=$?
    [[ "$_verify_rc" -eq 0 ]] \
        || log_warn "Environment check failed — run spfx-bootstrap to repair"
    state_verify_cache_write "$_verify_rc"
fi


NAME="${1:-}"; shift || true
PORT="4321"
HOST=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --port) PORT="${2:?--port requires a value}"; shift 2 ;;
        --host) HOST="${2:?--host requires a value}"; shift 2 ;;
        --help|-h)
            echo "Usage: spfx-dev <name> [--port <n>] [--host <ip>]"
            exit 0 ;;
        *) log_die "Unknown option: $1" ;;
    esac
done

validate_project_name "$NAME"
require_project "$NAME"

if [[ -z "$HOST" ]]; then HOST="$(get_local_ip)"; fi

echo ""
echo -e "  ${BOLD}┌──────────────────────────────────────────────┐${NC}"
printf   "  ${BOLD}│${NC}  Project  : %-33s${BOLD}│${NC}\n" "$NAME"
printf   "  ${BOLD}│${NC}  URL      : https://%-27s${BOLD}│${NC}\n" "${HOST}:${PORT}"
printf   "  ${BOLD}│${NC}  Pipeline : %-33s${BOLD}│${NC}\n" "$(detect_pipeline "$NAME")"
echo -e  "  ${BOLD}└──────────────────────────────────────────────┘${NC}"
echo ""
echo -e "  Workbench: ${CYAN}https://<tenant>.sharepoint.com/_layouts/workbench.aspx${NC}"
echo ""

if needs_install "$NAME"; then install_deps "$NAME"; fi

podman_dev "$NAME" "$HOST" "$PORT"
