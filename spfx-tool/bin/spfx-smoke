#!/usr/bin/env bash
# bin/spfx-smoke — End-to-end smoke test: scaffold a minimal real web part,
# build it, and produce a deployable .sppkg you can upload to a tenant.
#
# Unlike `spfx-test` (which exercises frozen heft-only fixtures that compile to
# lib/ but never package), this generates a *real* SPFx project via the Yeoman
# generator — so it has the gulp packaging phase and emits a true .sppkg under
# sharepoint/solution/, exactly what you upload to the App Catalog.
#
# Usage: spfx-smoke [name] [--keep] [--no-build]
#   name        project name (default: smoke-webpart)
#   --keep      do not remove a previous project of the same name first
#   --no-build  scaffold only, skip the build/package step
# shellcheck shell=bash
set -euo pipefail

export SPFX_DIR="${SPFX_DIR:-$HOME/dev/spfx}"
export LOG_FILE="${SPFX_DIR}/logs/spfx-smoke-$(date '+%Y%m%d-%H%M%S').log"
mkdir -p "${SPFX_DIR}/logs"

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/core.sh
source "${_SCRIPT_DIR}/lib/core.sh"
# shellcheck source=lib/runtime.sh
source "${_SCRIPT_DIR}/lib/runtime.sh"
# shellcheck source=lib/presets.sh
source "${_SCRIPT_DIR}/lib/presets.sh"

spfx_load_versions
require_podman

NAME="smoke-webpart"
_KEEP=0
_NO_BUILD=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --keep)     _KEEP=1;     shift ;;
        --no-build) _NO_BUILD=1; shift ;;
        --help|-h)
            echo "Usage: spfx-smoke [name] [--keep] [--no-build]"
            echo "  Scaffolds a minimal real web part and builds a deployable .sppkg."
            exit 0 ;;
        -*) log_die "Unknown option: $1" ;;
        *)  NAME="$1"; shift ;;
    esac
done

validate_project_name "$NAME"

PDIR="${SPFX_DIR}/projects/${NAME}"

log_step "SPFx smoke: ${NAME}"
log_info "Log: ${LOG_FILE}"

# ── 1. Clean slate (unless --keep) ────────────────────────────────────────────
# A previous scaffold left at this path would make `yo --force` merge into a
# stale tree; removing it first keeps the smoke run reproducible. node_modules
# may be owned by a container sub-UID under rootless Podman, so try podman
# unshare before a plain rm.
if [[ -d "$PDIR" && "$_KEEP" -eq 0 ]]; then
    log_info "Removing previous project at ${PDIR}..."
    podman unshare rm -rf "$PDIR" 2>/dev/null || rm -rf "$PDIR" 2>/dev/null || true
fi
mkdir -p "$PDIR"

# ── 2. Scaffold a real react web part (non-interactive) ───────────────────────
# The generator's --configFile path expects flat prompt keys, not the nested
# preset shape, so it silently falls back to interactive prompts and hangs with
# no TTY. The supported non-interactive route is CLI flags: each flag maps to a
# config value, which makes the matching prompt's `when` guard skip it.
#
#   --use-gulp true  → generates gulpfile.js + the package-solution task, which
#                      is what emits the deployable .sppkg. (SPFx 1.22 defaults
#                      to Heft, which compiles to lib/ but does NOT package.)
#   --skip-install   → we install separately below via install_deps.
#
# NOTE: passing --solution-name makes the generator ALWAYS create a subfolder
# named after the solution (app/index.js: shouldUseSubDir = solutionName !==
# undefined — unconditional, no flag to disable). So it writes to
# /workspace/<name>/, not /workspace/. We flatten that subfolder back up into
# /workspace so the rest of the pipeline (install/build/package), which assumes
# the project lives at the workspace root, works unchanged.
log_step "1 · Scaffold (generator ${SPFX_GENERATOR_VERSION})"
podman_exec_root "$NAME" "chown -R u:u /workspace" >> "${LOG_FILE}" 2>&1 || true
_scaffold='set -e
yo @microsoft/sharepoint \
    --solution-name "'"$NAME"'" \
    --component-type webpart \
    --component-name "'"$NAME"'" \
    --framework react \
    --environment spo \
    --package-manager npm \
    --use-gulp true \
    --skip-feature-deployment true \
    --is-domain-isolated false \
    --skip-install \
    --no-insight \
    --output /workspace
# Flatten /workspace/<name>/ → /workspace/ if the generator made a subfolder.
if [ -f "/workspace/'"$NAME"'/package.json" ]; then
    shopt -s dotglob
    mv /workspace/'"$NAME"'/* /workspace/
    rmdir "/workspace/'"$NAME"'" 2>/dev/null || true
fi'
run_exec "$NAME" "$_scaffold" >> "${LOG_FILE}" 2>&1 \
    || log_die "Scaffold failed — see ${LOG_FILE}"

# Verify the scaffold actually wrote a project at the workspace root. The
# generator can exit 0 while producing nothing (e.g. if it fell back to a
# prompt), so a package.json check is the real success signal — not exit code.
if [[ ! -f "${PDIR}/package.json" ]]; then
    log_die "Scaffold reported success but ${PDIR}/package.json is missing.
  Check ${LOG_FILE}. If you see 'create ${NAME}/package.json' there, the
  generator wrote to a subfolder that was not flattened — share the log."
fi
log_ok "Scaffolded real web part: ${PDIR}"

if [[ "$_NO_BUILD" -eq 1 ]]; then
    log_info "Skipping build (--no-build). Run: spfx-build ${NAME}"
    exit 0
fi

# ── 3. Install + production build ─────────────────────────────────────────────
log_step "2 · Install dependencies"
# Generator ran with --skip-install, so deps are always needed here.
install_deps "$NAME" >> "${LOG_FILE}" 2>&1 || log_die "npm install failed — see ${LOG_FILE}"

PIPELINE="$(detect_pipeline "$NAME")"
log_step "3 · Production build [${PIPELINE}]"
# Generated with --use-gulp, so gulpfile.js is present → 'hybrid' pipeline, and
# build_command runs the gulp ship tasks that emit the .sppkg.
if run_exec "$NAME" "$(build_command "$PIPELINE")" >> "${LOG_FILE}" 2>&1; then
    log_ok "Production build complete"
else
    log_die "Build failed — see ${LOG_FILE}"
fi

# ── 4. Locate and validate the .sppkg ─────────────────────────────────────────
log_step "4 · Package artifact"
shopt -s nullglob
SPPKG_FILES=( "${PDIR}/sharepoint/solution/"*.sppkg )
shopt -u nullglob

if [[ ${#SPPKG_FILES[@]} -eq 0 ]]; then
    log_die "Build succeeded but no .sppkg found at: ${PDIR}/sharepoint/solution/
  This project's pipeline was detected as '${PIPELINE}'. A deployable .sppkg
  requires the gulp package-solution phase (hybrid pipeline). If you see this,
  share ${LOG_FILE} so the packaging step can be diagnosed."
fi

SPPKG="${SPPKG_FILES[0]}"
SPPKG_SIZE="$(du -h "$SPPKG" | awk '{print $1}')"

if command -v unzip >/dev/null 2>&1; then
    if unzip -t "$SPPKG" >/dev/null 2>&1; then
        log_ok "Artifact integrity: ZIP valid"
    else
        log_warn "Artifact integrity: ZIP validation failed (the file may be corrupt)"
    fi
fi

log_ok "Deployable package: $(basename "$SPPKG") (${SPPKG_SIZE})"
echo ""
echo -e "  ${BOLD}.sppkg ready to upload:${NC}"
echo -e "    ${CYAN}${SPPKG}${NC}"
echo ""
echo -e "  ${BOLD}Next — upload to your tenant:${NC}"
echo -e "    1. Open your App Catalog:"
echo -e "       ${CYAN}https://<your-tenant>.sharepoint.com/sites/appcatalog${NC}"
echo -e "       (\"Apps for SharePoint\"). Requires App Catalog admin rights."
echo -e "    2. Upload the .sppkg above; when prompted, trust the solution."
echo -e "    3. On your site: gear ▸ Add an app ▸ add '${NAME}'."
echo -e "    4. Edit your home page ▸ '+' ▸ pick '${NAME}' ▸ Publish."
echo ""
