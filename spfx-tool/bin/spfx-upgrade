#!/usr/bin/env bash
# bin/spfx-upgrade — Controlled upgrade of Node/SPFx versions with rollback.
# Usage: spfx-upgrade --node <ver> | --spfx <ver> [--dry-run]
# shellcheck shell=bash
set -Eeuo pipefail

export SPFX_DIR="${SPFX_DIR:-$HOME/dev/spfx}"
export LOG_FILE="${SPFX_DIR}/logs/spfx-upgrade-$(date '+%Y%m%d-%H%M%S').log"
mkdir -p "${SPFX_DIR}/logs"

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/core.sh
source "${_SCRIPT_DIR}/lib/core.sh"
# shellcheck source=lib/runtime.sh
source "${_SCRIPT_DIR}/lib/runtime.sh"
# shellcheck source=lib/state.sh
source "${_SCRIPT_DIR}/lib/state.sh"

spfx_load_versions

_NEW_NODE=""; _NEW_SPFX=""; _DRY_RUN=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --node)    _NEW_NODE="${2:?--node requires a value}"; shift 2 ;;
        --spfx)    _NEW_SPFX="${2:?--spfx requires a value}"; shift 2 ;;
        --dry-run) _DRY_RUN=1;    shift   ;;
        --status)  state_rollback_status; exit 0 ;;
        --help|-h)
            echo "Usage: spfx-upgrade [--node <ver>] [--spfx <ver>] [--dry-run]"
            echo "       spfx-upgrade --status"
            exit 0 ;;
        *) log_die "Unknown option: $1" ;;
    esac
done

if [[ -z "$_NEW_NODE$_NEW_SPFX" ]]; then log_die "Specify at least one of: --node --spfx"; fi

if [[ "$_DRY_RUN" -eq 1 ]]; then
    log_step "Dry run — no changes applied"
    if [[ -n "$_NEW_NODE" ]]; then log_info "Would set NODE_VERSION=${_NEW_NODE}"; fi
    if [[ -n "$_NEW_SPFX" ]]; then log_info "Would set SPFX_GENERATOR_VERSION=${_NEW_SPFX}"; fi
    exit 0
fi

# validate_semver <value> <flag>
# Accepts N, N.N, or N.N.N — rejects anything with | " \ that could
# corrupt the sed substitution in apply_version or break versions.env parsing.
# Defined here so a bad --node/--spfx value fails BEFORE rollback is armed.
validate_semver() {
    local val="$1" flag="$2"
    [[ "$val" =~ ^[0-9]+(\.[0-9]+){0,2}$ ]] \
        || log_die "Invalid version for ${flag}: '${val}' — expected N, N.N, or N.N.N"
}

apply_version() {
    local key="$1" val="$2"
    # val is pre-validated by validate_semver; safe chars only, no | " \ possible.
    sed -i "s|^${key}=.*|${key}=\"${val}\"|" "$VENV"
    log_ok "Set ${key}=${val}"
}

# Validate versions before arming rollback — a bad value must not trigger
# state_rollback_exec, since nothing has been modified yet at this point.
if [[ -n "$_NEW_NODE" ]]; then validate_semver "$_NEW_NODE" "--node"; fi
if [[ -n "$_NEW_SPFX" ]]; then validate_semver "$_NEW_SPFX" "--spfx"; fi

VENV="${SPFX_DIR}/versions.env"
state_rollback_arm "upgrade-$(date '+%Y%m%dT%H%M%S')"
_on_error() { log_err "Upgrade failed — rolling back"; state_rollback_exec; }
trap _on_error ERR

SNAPSHOT="$(state_snapshot_create "pre-upgrade")"
log_info "Snapshot: $SNAPSHOT"


log_step "Applying version changes"
if [[ -n "$_NEW_NODE" ]]; then apply_version "NODE_VERSION"            "$_NEW_NODE"; fi
if [[ -n "$_NEW_SPFX" ]]; then apply_version "SPFX_GENERATOR_VERSION" "$_NEW_SPFX"; fi

# shellcheck source=/dev/null
source "$VENV"
validate_node_spfx_compat

log_step "Reinstalling toolchain"
"${SPFX_DIR}/bin/spfx-bootstrap" --skip-verify

log_step "Post-upgrade verification"
"${SPFX_DIR}/bin/spfx-verify"

state_rollback_commit
state_verify_cache_invalidate
trap - ERR

log_ok "Upgrade complete"
echo ""
echo -e "  ${DIM}Rollback: cp ${SPFX_DIR}/state/rollback/active.env ${VENV}${NC}"
echo -e "  ${DIM}Snapshot: ${SNAPSHOT}${NC}"
echo ""
