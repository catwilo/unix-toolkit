#!/usr/bin/env bash
# bin/spfx-new — Scaffold a new SPFx project.
# Usage: spfx-new <name> [preset]
#   preset: react-webpart | extension | library | ace | interactive (default)
# shellcheck shell=bash
set -euo pipefail

export SPFX_DIR="${SPFX_DIR:-$HOME/dev/spfx}"
export LOG_FILE="${SPFX_DIR}/logs/spfx-new-$(date '+%Y%m%d-%H%M%S').log"
mkdir -p "${SPFX_DIR}/logs"

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/core.sh
source "${_SCRIPT_DIR}/lib/core.sh"
# shellcheck source=lib/presets.sh
source "${_SCRIPT_DIR}/lib/presets.sh"

case "${1:-}" in
    --help|-h)
        echo "Usage: spfx-new <name> [preset]"
        echo "Presets: ${SPFX_PRESET_TYPES[*]}"
        exit 0 ;;
esac

require_podman

NAME="${1:-}"; shift || true
PRESET="${1:-interactive}"; shift || true

validate_project_name "$NAME"

PDIR="${SPFX_DIR}/projects/${NAME}"
if [[ -d "$PDIR" ]]; then
    log_warn "Project directory already exists: $PDIR"
    printf "  Continue and overwrite? [y/N]: "
    read -r _r || true
    [[ "${_r:-N}" =~ ^[yY]$ ]] || { log_info "Aborted."; exit 0; }
fi
mkdir -p "$PDIR"

log_step "Scaffolding '${NAME}' [${PRESET}]"

if [[ "$PRESET" == "interactive" ]]; then
    scaffold_project "$NAME" "interactive"
else
    scaffold_from_config "$NAME" "$PRESET"
fi

log_ok "Project ready: $PDIR"
echo ""
echo -e "  Next steps:"
echo -e "    ${CYAN}spfx-dev ${NAME}${NC}    live dev server"
echo -e "    ${CYAN}spfx-build ${NAME}${NC}  production build → .sppkg"
