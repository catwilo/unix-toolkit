# versions.env — Single source of truth for all pinned versions.
# Edit here to upgrade; never hardcode versions elsewhere.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_VERSION="22"

# ── SPFx toolchain ────────────────────────────────────────────────────────────
# SPFx 1.22+: only generator and yo are installed globally.
# heft (@rushstack/heft) is project-local — installed via npm install per project.
SPFX_GENERATOR_VERSION="1.22.2"
YO_VERSION="5.0.0"

# ── Podman images (Debian path only) ─────────────────────────────────────────
# PODMAN_BASE_IMAGE: upstream image pulled from registry.
# PODMAN_IMAGE:      local image built on top of the base, adds non-root user w.
PODMAN_BASE_IMAGE="node:22-bookworm-slim"
PODMAN_IMAGE="localhost/spfx-dev:latest"

# ── Static analysis ───────────────────────────────────────────────────────────
SHELLCHECK_VERSION="0.10.0"
SHFMT_VERSION="3.8.0"

# ── Known compatible Node/SPFx matrix ────────────────────────────────────────
# SPFx 1.20.x: Node 18 LTS
# SPFx 1.21.x: Node 18 LTS, Node 20 LTS
# SPFx 1.22.x: Node 18 LTS, Node 20 LTS, Node 22 LTS
SPFX_MIN_NODE="18"
SPFX_MAX_NODE="22"
