# ── nvim-setup pinned versions ────────────────────────────────────────────────
# Single source of truth. Edit here, never hardcode elsewhere.

NVIM_VERSION="0.12.2"          # installed to ~/.local (official tarball)
NODE_MAJOR="22"                # host node line for LSP servers (matches spfx-tool)

# ── LSP servers installed via npm -g ─────────────────────────────────────────
# Format: "<npm-package>@<version>" — one per line in NPM_LSP_SERVERS.
# To add a language server: add its npm package here AND a line in lib/servers.lua
NPM_LSP_SERVERS=(
  "typescript@6.0.3"
  "typescript-language-server@5.3.0"
  "vscode-langservers-extracted@4.10.0"   # html, css, json, eslint
)

# ── Non-npm servers (binaries) ───────────────────────────────────────────────
# lua-language-server ships as a prebuilt binary, not npm.
LUA_LS_VERSION="3.13.6"
