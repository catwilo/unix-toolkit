#!/usr/bin/env bash
# wifi-showpass <ssid> — reveal the stored password from the NM keyring.
# Sensitive: requires explicit confirmation before printing in clear.
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root
require_nm

ssid="${1:-}"
[[ -n "${ssid}" ]] || die "uso: wifi-showpass <ssid>"
nm_profile_exists "${ssid}" || die "no existe la red guardada '${ssid}'"

warn "vas a mostrar una contraseña en CLARO por pantalla."
read -r -p "¿continuar? [escribe 'si' para confirmar]: " ans
[[ "${ans}" == "si" ]] || { info "cancelado"; exit 0; }

psk="$(nmcli --show-secrets -g 802-11-wireless-security.psk \
        connection show "${ssid}" 2>/dev/null || true)"

if [[ -n "${psk}" ]]; then
    printf 'ssid     : %s\n' "${ssid}"
    printf 'password : %s\n' "${psk}"
    log INFO "wifi-showpass: secreto mostrado para '${ssid}'"
else
    die "no se pudo recuperar el secreto (¿perfil sin PSK o sin agente NM?)"
fi
