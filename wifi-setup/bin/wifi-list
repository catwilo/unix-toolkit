#!/usr/bin/env bash
# wifi-list [usb|native] — live scan of networks currently in the air.
# (Different from wifi-saved, which shows YOUR stored bank.)
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_nm

ifn=""
if [[ -n "${1:-}" ]]; then
    case "$1" in usb|native) ifn="$(detect_iface "$1")" ;; *) die "uso: wifi-list [usb|native]";; esac
    [[ -n "${ifn}" ]] || die "antena '$1' no presente"
fi

if [[ -n "${ifn}" ]]; then
    nmcli -f IN-USE,SSID,SIGNAL,SECURITY device wifi list ifname "${ifn}" --rescan yes
else
    nmcli -f IN-USE,SSID,SIGNAL,SECURITY device wifi list --rescan yes
fi
