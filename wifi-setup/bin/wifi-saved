#!/usr/bin/env bash
# wifi-saved — list the saved network bank: name, priority, active?, pinned?
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_nm

pinned="$(pin_get)"
active="$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null \
            | awk -F: 'NF>=2 && $2!="" {print $1}')"

printf '%-22s %-9s %-7s %-7s %-9s\n' "RED (SSID)" "PRIORIDAD" "ACTIVA" "ANCLADA" "FAILOVER"
printf '%-22s %-9s %-7s %-7s %-9s\n' "----------" "---------" "------" "-------" "--------"

while IFS= read -r ssid; do
    [[ -n "${ssid}" ]] || continue
    [[ "${ssid}" == *-failover ]] && continue   # twin shown as part of its base
    prio="$(nmcli -g connection.autoconnect-priority connection show "${ssid}" 2>/dev/null || echo '?')"
    is_active="no";  printf '%s\n' "${active}" | grep -Fxq "${ssid}" && is_active="sí"
    is_pinned="no";  [[ "${ssid}" == "${pinned}" ]] && is_pinned="sí"
    has_fo="no";     nmcli -t -f NAME connection show 2>/dev/null | grep -Fxq "${ssid}-failover" && has_fo="sí"
    printf '%-22s %-9s %-7s %-7s %-9s\n' "${ssid}" "${prio}" "${is_active}" "${is_pinned}" "${has_fo}"
done < <(nm_saved_ssids)
