#!/usr/bin/env bash
# wifi-failover <status|test|on|off> — control the failover monitor.
#   status : show timer state and last log lines
#   test   : run one failover check right now (bypass the 20s wait)
#   on/off : enable/disable the periodic timer
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root

TIMER="wifi-failover.timer"

case "${1:-status}" in
    status)
        systemctl status "${TIMER}" --no-pager 2>/dev/null | head -12 || true
        echo "── últimas líneas del log ──"
        tail -n 15 "${WS_LOG}" 2>/dev/null || echo "(sin log todavía)"
        ;;
    test)
        require_nm
        info "ejecutando una comprobación de failover ahora…"
        "${WS_BIN}/wifi-failover-monitor" || warn "el monitor terminó con código $?"
        ;;
    on)
        systemctl enable --now "${TIMER}" >/dev/null 2>&1
        ok "failover activado (cada 20s)"
        ;;
    off)
        systemctl disable --now "${TIMER}" >/dev/null 2>&1
        ok "failover desactivado"
        ;;
    *)
        die "uso: wifi-failover <status|test|on|off>"
        ;;
esac
