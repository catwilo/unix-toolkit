#!/usr/bin/env bash
# wifi-panic — last resort: bring both antennas up, restart NM cleanly,
# force a rescan + reconnect, then run one failover pass.
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root
require_cmd nmcli

log WARN "wifi-panic: reinicio limpio del stack de red"

usb="$(detect_iface usb)"
native="$(detect_iface native)"
[[ -n "${usb}" ]]    && iface_up "${usb}"
[[ -n "${native}" ]] && iface_up "${native}"

# Release any pin: panic means "get me online by any means".
pin_clear

systemctl restart NetworkManager
sleep 3

nmcli radio wifi on >/dev/null 2>&1 || true
nmcli device wifi rescan >/dev/null 2>&1 || true
sleep 2

# Let the failover engine pick the best working network.
if [[ -x "${WS_BIN}/wifi-failover-monitor" ]]; then
    "${WS_BIN}/wifi-failover-monitor" || true
fi

if has_internet ""; then
    ok "wifi-panic: conectividad restaurada"
else
    warn "wifi-panic: aún sin Internet — revisa: wifi-list  y  wifi-saved"
fi
