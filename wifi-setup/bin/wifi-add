#!/usr/bin/env bash
# wifi-add [ssid] — add a network to the bank as a DUAL profile:
#   <ssid>           bound to USB antenna  (primary, high priority)
#   <ssid>-failover  bound to native antenna (backup, low priority)
# Both share a persistent MAC (stable IP). Only the primary may take a fixed IP;
# all others use DHCP (+fixed MAC, which already stabilizes the lease).
#
#   Enter with no SSID, or empty input -> defaults to "cursed".
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root
require_nm

DEFAULT_SSID="cursed"
PRIO_PRIMARY=20
PRIO_FAILOVER=5

ssid="${1:-}"
if [[ -z "${ssid}" ]]; then
    read -r -p "SSID [${DEFAULT_SSID}]: " ssid
    ssid="${ssid:-${DEFAULT_SSID}}"
fi

nm_profile_exists "${ssid}" && die "ya existe '${ssid}' — usa wifi-passwd o wifi-rm"

usb="$(detect_iface usb)"; native="$(detect_iface native)"
[[ -n "${usb}" ]] || die "no se detectó la antena USB"

# Persistent shared MAC derived from the SSID (option A: per-profile, stable).
mac_h="$(printf 'wifi-setup-%s' "${ssid}" | md5sum | cut -c1-6)"
mac="$(printf '00:1a:2b:%s:%s:%s' "${mac_h:0:2}" "${mac_h:2:2}" "${mac_h:4:2}")"

passwd="$(read_passphrase)"

# ── Primary profile: bound to USB ────────────────────────────────────────────
nmcli connection add type wifi con-name "${ssid}" ssid "${ssid}" \
    -- wifi-sec.key-mgmt wpa-psk wifi-sec.psk "${passwd}" \
    connection.interface-name "${usb}" \
    connection.autoconnect yes connection.autoconnect-priority "${PRIO_PRIMARY}" \
    802-11-wireless.cloned-mac-address "${mac}" >/dev/null
ok "perfil principal '${ssid}' creado (USB ${usb}, MAC ${mac})"

# Optional fixed IP — ONLY offered for the primary network, and only if asked.
read -r -p "¿IP fija para '${ssid}'? (Enter = DHCP, o escribe IP ej 10.26.35.70): " want_ip || want_ip=""
if [[ -n "${want_ip}" ]]; then
    gw="$(printf '%s' "${want_ip}" | sed 's/\.[0-9]*$/.110/')"
    read -r -p "gateway [${gw}]: " want_gw || want_gw=""; want_gw="${want_gw:-${gw}}"
    nmcli connection modify "${ssid}" \
        ipv4.method manual ipv4.addresses "${want_ip}/24" \
        ipv4.gateway "${want_gw}" ipv4.dns "1.1.1.1 8.8.8.8" >/dev/null
    nmcli connection up "${ssid}" ifname "${usb}" >/dev/null 2>&1 || true
    sleep 3
    if has_internet ""; then
        ok "IP fija ${want_ip} activa con Internet"
    else
        warn "IP fija sin Internet — revirtiendo a DHCP"
        nmcli connection modify "${ssid}" ipv4.method auto ipv4.addresses "" ipv4.gateway "" >/dev/null
        nmcli connection up "${ssid}" ifname "${usb}" >/dev/null 2>&1 || true
    fi
fi

# ── Failover profile: bound to native, DHCP ──────────────────────────────────
if [[ -n "${native}" ]]; then
    nmcli connection add type wifi con-name "${ssid}-failover" ssid "${ssid}" \
        -- wifi-sec.key-mgmt wpa-psk wifi-sec.psk "${passwd}" \
        connection.interface-name "${native}" \
        ipv4.method auto \
        connection.autoconnect yes connection.autoconnect-priority "${PRIO_FAILOVER}" \
        802-11-wireless.cloned-mac-address "${mac}" >/dev/null
    ok "perfil failover '${ssid}-failover' creado (nativa ${native}, DHCP)"
else
    warn "antena nativa no detectada — sin perfil de failover"
fi
unset passwd

log INFO "wifi-add: dual profile '${ssid}' (USB primary + native failover)"
echo "conéctate con: wifi-connect ${ssid}"
