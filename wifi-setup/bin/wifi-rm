#!/usr/bin/env bash
# wifi-rm <ssid> — remove a saved network from the bank.
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root
require_nm

ssid="${1:-}"
[[ -n "${ssid}" ]] || die "uso: wifi-rm <ssid>"
nm_profile_exists "${ssid}" || die "no existe la red guardada '${ssid}'"

nmcli connection delete "${ssid}" >/dev/null
ok "perfil principal '${ssid}' eliminado"
# Also remove the failover twin if present.
if nm_profile_exists "${ssid}-failover"; then
    nmcli connection delete "${ssid}-failover" >/dev/null
    ok "perfil failover '${ssid}-failover' eliminado"
fi
# If it was pinned, releasing the pin keeps state consistent.
[[ "$(pin_get)" == "${ssid}" ]] && pin_clear || true
log INFO "wifi-rm: '${ssid}' (+failover) borrado"
