#!/usr/bin/env bash
# wifi-mac <usb|native> <persistent|real|random|manual [MAC]> — manage MAC.
#
#   persistent  fixed fake MAC that looks like a real PC NIC, stable forever
#               (default choice; this is what keeps the IP from changing)
#   real        use the hardware's permanent MAC
#   random      regenerate a new random MAC now (NOT persistent)
#   manual MAC  set a specific MAC you provide
#
# Applies to the NM connection bound to that antenna's active SSID and to the
# device default, so it survives reconnects.
set -Eeuo pipefail
IFS=$'\n\t'
source /opt/wifi-setup/lib/common.sh

require_root
require_nm

role="${1:-}"; mode="${2:-}"; manual_mac="${3:-}"
case "${role}" in usb|native) ;; *) die "uso: wifi-mac <usb|native> <persistent|real|random|manual [MAC]>";; esac
iface="$(detect_iface "${role}")"
[[ -n "${iface}" ]] || die "antena '${role}' no encontrada"

# Generate a stable fake MAC with a real-vendor OUI (Intel 00:1A:2B style),
# derived deterministically from the interface so it's the SAME every time.
gen_persistent_mac() {
    local seed hash
    seed="wifi-setup-${iface}"
    hash="$(printf '%s' "${seed}" | md5sum | cut -c1-6)"
    # OUI 00:1A:2B (a real allocated vendor block) + 3 bytes from the hash.
    printf '00:1a:2b:%s:%s:%s' "${hash:0:2}" "${hash:2:2}" "${hash:4:2}"
}

valid_mac() { printf '%s' "$1" | grep -qiE '^([0-9a-f]{2}:){5}[0-9a-f]{2}$'; }

# The NM connection currently using this device (if any), else fall back to
# setting it as the device-level default for future connections.
conn_for_iface() {
    nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null \
        | awk -F: -v d="${iface}" '$2==d{print $1; exit}'
}

apply_mac() {
    local value="$1"          # a MAC, or the keyword "permanent"/"random"
    local conn; conn="$(conn_for_iface)"
    if [[ -z "${conn}" ]]; then
        warn "ninguna conexión activa en ${iface}; se aplicará al reconectar"
        return 0
    fi
    # cloned-mac-address accepts: a MAC, "permanent", "random", "stable".
    nmcli connection modify "${conn}" 802-11-wireless.cloned-mac-address "${value}" >/dev/null
    info "reaplicando conexión '${conn}' en ${iface}…"
    nmcli connection up "${conn}" >/dev/null 2>&1 || warn "reconecta manualmente si es necesario"
}

case "${mode}" in
    persistent)
        mac="$(gen_persistent_mac)"
        apply_mac "${mac}"
        ok "MAC persistente (estilo PC) fijada en ${iface}: ${mac}"
        ;;
    real)
        apply_mac "permanent"
        ok "MAC real del hardware fijada en ${iface}"
        ;;
    random)
        apply_mac "random"
        warn "MAC aleatoria aplicada en ${iface} — NO es persistente, la IP puede cambiar"
        ;;
    manual)
        [[ -n "${manual_mac}" ]] || die "falta la MAC: wifi-mac ${role} manual AA:BB:CC:DD:EE:FF"
        valid_mac "${manual_mac}" || die "MAC inválida: ${manual_mac}"
        apply_mac "${manual_mac}"
        ok "MAC manual fijada en ${iface}: ${manual_mac}"
        ;;
    *)
        # No mode: show current.
        echo "MAC actual de ${iface}: $(cat "/sys/class/net/${iface}/address" 2>/dev/null)"
        echo "uso: wifi-mac ${role} <persistent|real|random|manual [MAC]>"
        ;;
esac
log INFO "wifi-mac: ${role}/${iface} modo=${mode:-show}"
