# rsync-folder profile template
# Copiar a $XDG_CONFIG_HOME/rsync-folder/profiles/<nombre>.env y rellenar.
# Campos obligatorios: SOURCE, DESTINATION, DIRECTION
# El resto son opcionales (se muestran los defaults).

# --- Endpoints ---
SOURCE=""           # ruta absoluta local, ej: /storage/emulated/0/Download
DESTINATION=""      # ruta local O user@host:/ruta (SSH remoto)

# --- Dirección ---
# push  → SOURCE → DESTINATION (unidireccional)
# pull  → DESTINATION → SOURCE (unidireccional, roles invertidos)
# both  → dos watchers independientes, uno por sentido
DIRECTION="push"

# --- Comportamiento de sincronización ---
DEBOUNCE_SEC=3
MAX_RETRIES=5
RETRY_DELAY=5

# --- Clave SSH ---
# Ruta absoluta a la clave privada SSH. Dejar vacío para usar el agente SSH.
SSH_KEY=""

# --- Excludes ---
# Por defecto usa el excludes.txt compartido; sobreescribir por perfil si necesario.
# EXCLUDES_FILE="/ruta/a/excludes-custom.txt"

# --- Backup al sobreescribir ---
# 1 = guardar copia de archivos sobreescritos en DESTINATION/.rsync-backup/YYYYMMDD/
# Recomendado para DIRECTION=both.
BACKUP_ON_OVERWRITE=0
